{
  "name": "@stoa/insight-engine",
  "version": "0.0.1",
  "description": "Multi-agent Polymarket analysis engine. Four specialist Claude agents (News, Sentiment, Historical, Market Structure) plus a Judge aggregator, with Trading-R1-style traces pinned to Arc via TracePin and stored on IPFS.",
  "license": "MIT",
  "author": "Stoa contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cloakie47/stoa.git",
    "directory": "packages/insight-engine"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "viem": "^2.39.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "keywords": [
    "polymarket",
    "claude",
    "anthropic",
    "trading-r1",
    "multi-agent",
    "x402",
    "arc",
    "ipfs"
  ]
}
