{
  "name": "@stoa/polymarket-client",
  "version": "0.0.1",
  "description": "Thin wrapper around @polymarket/clob-client-v2 for Stoa InsightAgent. Exposes a stable surface (getMarket, prepareOrder, submitOrder, getBuilderTrades, cancelOrder) and isolates the smoke-test path from real submission.",
  "license": "MIT",
  "author": "Stoa contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cloakie47/stoa.git",
    "directory": "packages/polymarket-client"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke:prepare": "tsx scripts/smoke-test-polymarket.ts"
  },
  "dependencies": {
    "@polymarket/clob-client-v2": "^1.0.0",
    "viem": "^2.39.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "keywords": [
    "polymarket",
    "clob",
    "prediction-markets",
    "builder-code"
  ]
}
