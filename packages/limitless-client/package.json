{
  "name": "@stoa/limitless-client",
  "version": "0.0.1",
  "description": "Thin wrapper around the Limitless Exchange Programmatic API for the Stoa InsightAgent bot. Exposes a stable surface (getMarket, createSubAccount, prepareOrder, submitOrder, cancelOrder, getOpenOrders, getTrades) on top of Limitless's HMAC-auth + delegated-signing model.",
  "license": "MIT",
  "author": "Stoa contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cloakie47/stoa.git",
    "directory": "packages/limitless-client"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke:markets": "tsx scripts/smoke-test-markets.ts"
  },
  "dependencies": {
    "viem": "^2.39.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "keywords": [
    "limitless",
    "prediction-markets",
    "base",
    "stoa"
  ]
}
