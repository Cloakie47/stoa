# Stoa + InsightAgent — environment template. Copy to `.env` and fill in.
# .env is gitignored. Never commit secrets.

# ── Polymarket builder integration ───────────────────────────────────────────
# bytes32 hex from polymarket.com/settings?tab=builder (Unverified tier — 100 relayer txns/day)
POLY_BUILDER_CODE=

# ── Smart contract deployment ────────────────────────────────────────────────
# Funded deployer wallet on Arc Testnet (USDC is the native gas asset)
DEPLOYER_PRIVATE_KEY=

# ── RPC endpoints ────────────────────────────────────────────────────────────
ARC_TESTNET_RPC=https://rpc.testnet.arc.network
POLYGON_RPC=https://polygon-rpc.com

# ── Off-chain services ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
CIRCLE_API_KEY=

# ── insight-engine (multi-agent Polymarket analysis) ─────────────────────────
# REQUIRED for any live LLM call. Get from https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Deployed TracePin contract on Arc Testnet — used to anchor analysis traces.
TRACEPIN_ADDRESS=0x657355b621494C5F99253ce9A4c2cE8B9b488B7B

# IPFS pinning. Prefer PINATA_JWT (one-step setup: sign up at pinata.cloud,
# create an API key, copy the JWT). STORACHA_KEY+STORACHA_PROOF is a more
# decentralized alternative but requires the storacha CLI to provision a space
# and a delegated signing key.
PINATA_JWT=
# STORACHA_KEY=
# STORACHA_PROOF=

# Optional — sentiment agent gracefully falls back to web_search without these.
X_BEARER_TOKEN=
NEYNAR_API_KEY=
