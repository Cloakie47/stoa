# Stoa analyzer — local development env. Copy to .env and fill in.
# For Railway, set the same vars in the Railway dashboard (Variables tab).

# ── Routing & auth ──────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
BOT_INTERNAL_URL=https://stoa-bot.stoa-build.workers.dev
ANALYZER_HMAC_SECRET=replace-with-`openssl rand -hex 32`

# ── Telegram & LLM ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
ANTHROPIC_API_KEY=

# ── Wallets ─────────────────────────────────────────────────────────────────
WALLET_ENCRYPTION_KEY=
OPERATOR_PRIVATE_KEY=
STOA_RECIPIENT_OPERATOR=
STOA_RECIPIENT_MAINTAINERS=
STOA_RECIPIENT_CANTEEN=

# ── Stoa contracts (Arc Testnet defaults; override only if redeployed) ─────
STOA_SETTLER=0x05a98A1dCa17917B6e8B19306c1653fA9FC5d689
STOA_SPLITTER=0x114942B5FeebFDf9F1FA2F161eA9C2A1754C407F
STOA_TRACEPIN=0x657355b621494C5F99253ce9A4c2cE8B9b488B7B

# ── Optional ────────────────────────────────────────────────────────────────
PINATA_JWT=
LIMITLESS_TOKEN_ID=
LIMITLESS_TOKEN_SECRET=
